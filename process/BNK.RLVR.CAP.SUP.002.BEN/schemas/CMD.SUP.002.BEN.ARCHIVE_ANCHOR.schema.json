{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.banking/process/BNK.RLVR.CAP.SUP.002.BEN/schemas/CMD.SUP.002.BEN.ARCHIVE_ANCHOR.schema.json",
  "title": "ArchiveAnchorCommand",
  "description": "Payload for CMD.SUP.002.BEN.ARCHIVE_ANCHOR — flip anchor_status from ACTIVE to ARCHIVED.",
  "type": "object",
  "additionalProperties": false,
  "required": ["command_id", "reason"],
  "properties": {
    "command_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "UUIDv7 (RFC 9562 §5.7)."
    },
    "reason": {
      "type": "string",
      "enum": [
        "PROGRAMME_EXIT_SUCCESS",
        "PROGRAMME_EXIT_DROPOUT",
        "PROGRAMME_EXIT_TRANSFER",
        "ADMINISTRATIVE_ARCHIVAL"
      ]
    },
    "comment": {
      "type": "string",
      "maxLength": 1000,
      "description": "Optional free-text annotation for the audit trail."
    }
  }
}

# Claude Code runtime artefacts
.claude/scheduled_tasks.lock
**/.claude/data/

# Python bytecode (e.g. .claude/skills/sketch-miro/sketch_miro.py)
__pycache__/
*.pyc
tasks/BOARD.md

# Python tool caches — pytest / ruff / mypy. Promoted to root so future
# capabilities don't each need their own nested .gitignore for these.
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Python packaging artefacts
*.egg-info/

# .NET build output — promoted to root for the same reason. Safe today:
# no tracked file lives under nested bin/ or obj/ anywhere (verified). The new
# Deployment contract puts NO bin/ or obj/ under deployment/.
bin/
obj/
# …except the repo-root /bin/, which holds the committed `kpack` container
# wrapper (the single knowledge CLI). Re-include the dir then the file —
# nested sources/**/bin/ build dirs stay ignored.
!/bin/
!/bin/kpack

# Python virtualenvs
.venv/
.venv-*/
venv/
env/

# Runtime logs
logs/
**/logs/
*.log

# Secrets / local env
.env
.env.local
.env.*.local
docs/tools/structurizr.watch.dev.json
*.pem
*.key

# Deployment contract — committed-by-design files (CLAUDE.md, section
# "Deployment contract (local + dev)"). The per-component .env under
# deployment/local/ carries only the deterministic COMPONENT_PORT and
# platform service-name URLs (e.g. amqp://...@rabbitmq:5672/) — no
# secrets, stable per capability, so it MUST be tracked. The whitelists
# below override the broad `.env` rule above.
!sources/**/deployment/local/.env
!sources/**/deployment/local/.env.example

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp

# Claude Code runtime artefacts
.claude/scheduled_tasks.lock
**/.claude/data/

# Python bytecode (e.g. .claude/skills/sketch-miro/sketch_miro.py)
__pycache__/
*.pyc
tasks/BOARD.md

# Python virtualenvs
.venv/
.venv-*/
venv/
env/

# Runtime logs
logs/
**/logs/
*.log

# Secrets / local env
.env
.env.local
.env.*.local
docs/tools/structurizr.watch.dev.json
*.pem
*.key

# Deployment contract — committed-by-design files (CLAUDE.md, section
# "Deployment contract (local + dev)"). The per-component .env under
# deployment/local/ carries only the deterministic COMPONENT_PORT and
# platform service-name URLs (e.g. amqp://...@rabbitmq:5672/) — no
# secrets, stable per capability, so it MUST be tracked. The whitelists
# below override the broad `.env` rule above.
!sources/**/deployment/local/.env
!sources/**/deployment/local/.env.example

# Editor / OS noise
.DS_Store
Thumbs.db
*.swp

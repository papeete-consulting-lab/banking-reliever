# Deployment contract — local environment variables (CLAUDE.md §
# "Deployment contract"). This file is committed-by-design: no secrets,
# only deterministic values stable per capability + kind, plus
# platform service-name URLs. Whitelisted in the repo .gitignore via
# `!sources/**/deployment/local/.env`.

# ── Deterministic component port ────────────────────────────────────────────
# COMPONENT_PORT = 20000 + (int(sha256(f"{capability_id}:{kind}").hexdigest()[:8], 16) % 9000)
# capability_id = BNK.RLVR.CAP.CHN.001.DSH , kind = bff  → 22328
# Same capability+kind → same port across every branch and every laptop.
COMPONENT_PORT=22328

# ── Platform service-name URLs ──────────────────────────────────────────────
# Joined via the shared external Docker network `reliever-platform`.
# No host ports — the platform broker is resolved by service name.
AMQP_URL=amqp://guest:guest@rabbitmq:5672/

# ── Branch slug (queue NAMES + telemetry environment tag) ───────────────────
# Bus isolation across concurrent worktrees: queue names carry this slug.
# Exchange NAMES are producer-owned and shared with upstream stubs — those
# are not branch-tagged.
BRANCH=task-007-migrate-bff-to-deployment-contract

# ── CORS allowlist for the sibling frontend ─────────────────────────────────
# Re-derived deterministically with kind=frontend:
#   FRONTEND_PORT = 20000 + (int(sha256("BNK.RLVR.CAP.CHN.001.DSH:frontend").hexdigest()[:8], 16) % 9000) = 22695
# TASK-008 owns that allocation; this BFF must allowlist it now.
CORS_ALLOWED_ORIGINS=http://localhost:22695

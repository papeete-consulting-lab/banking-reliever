{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.banking/process/BNK.RLVR.CAP.BSP.001.SCO/schemas/BNK.RLVR.RVT.BSP.001.CURRENT_SCORE_RECOMPUTED.schema.json",
  "title": "CurrentScoreRecomputedEvent",
  "description": "Payload of BNK.RLVR.RVT.BSP.001.CURRENT_SCORE_RECOMPUTED — emitted by AGG.SCORE_OF_BENEFICIARY on every accepted CMD.RECOMPUTE_SCORE. Carries the full post-recomputation state of BNK.RLVR.RES.BSP.001.CURRENT_SCORE plus the trigger metadata so consumers can correlate to the upstream RVT (BNK.RLVR.RVT.BSP.004.PAYMENT_GRANTED / PAYMENT_BLOCKED, BNK.RLVR.RVT.BSP.001.RELAPSE_SIGNAL_QUALIFIED / PROGRESSION_SIGNAL_QUALIFIED).",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "case_id", "evaluation_id", "score_value", "delta_score", "model_version", "evaluation_type", "computation_timestamp", "trigger", "contributing_factors"],
  "properties": {
    "envelope":      { "$ref": "#/$defs/Envelope" },
    "case_id":       { "$ref": "#/$defs/Uuidv7" },
    "evaluation_id": { "$ref": "#/$defs/Uuidv7" },
    "score_value":   { "type": "number", "description": "Post-recomputation absolute value." },
    "delta_score":   { "type": "number", "description": "score_value - prior score_value; sign matches the polarity of the trigger." },
    "model_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "evaluation_type": {
      "type": "string",
      "const": "CURRENT",
      "description": "Per BNK.RLVR.OBJ.BSP.001.EVALUATION — CURRENT for post-trigger recomputations (always for this RVT)."
    },
    "computation_timestamp": { "type": "string", "format": "date-time" },
    "trigger": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind", "event_id", "polarity"],
      "properties": {
        "kind": {
          "type": "string",
          "enum": ["TRANSACTION_AUTHORIZED", "TRANSACTION_REFUSED", "RELAPSE_SIGNAL", "PROGRESSION_SIGNAL"],
          "description": "Discriminator — see commands.yaml.trigger_kinds."
        },
        "event_id":    { "$ref": "#/$defs/Uuidv7", "description": "UUIDv7 of the upstream RVT that drove this recomputation; serves as the idempotency key." },
        "polarity":    { "type": "string", "enum": ["positive", "negative"] },
        "amount":      { "type": ["number", "null"], "description": "Transaction amount when kind is TRANSACTION_*." },
        "category":    { "type": ["string", "null"] },
        "impact_score": { "type": ["number", "null"], "description": "Signal magnitude when kind is *_SIGNAL." }
      }
    },
    "contributing_factors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "weight", "value"],
        "properties": {
          "name":   { "type": "string" },
          "weight": { "type": "number" },
          "value":  { "type": ["number", "string", "null"] }
        }
      }
    }
  },
  "$defs": {
    "Uuidv7": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "Envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_id", "schema_version", "emitted_at", "emitting_capability", "correlation_id", "causation_id"],
      "properties": {
        "message_id":          { "$ref": "#/$defs/Uuidv7" },
        "schema_version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "emitted_at":          { "type": "string", "format": "date-time" },
        "emitting_capability": { "type": "string", "const": "BNK.RLVR.CAP.BSP.001.SCO" },
        "correlation_id":      { "$ref": "#/$defs/Uuidv7", "description": "case_id." },
        "causation_id":        { "$ref": "#/$defs/Uuidv7", "description": "trigger.event_id (the upstream RVT that caused this recomputation)." }
      }
    }
  }
}

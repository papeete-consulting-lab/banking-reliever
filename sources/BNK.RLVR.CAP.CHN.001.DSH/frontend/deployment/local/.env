# Deployment contract — local environment variables (CLAUDE.md §
# "Deployment contract"). This file is committed-by-design: no secrets,
# only deterministic values stable per capability + kind, plus
# platform service-name URLs. Whitelisted in the repo .gitignore via
# `!sources/**/deployment/local/.env`.

# ── Deterministic component port ────────────────────────────────────────────
# COMPONENT_PORT = 20000 + (int(sha256(f"{capability_id}:{kind}").hexdigest()[:8], 16) % 9000)
# capability_id = BNK.RLVR.CAP.CHN.001.DSH , kind = frontend  → 22695
# Same capability+kind → same port across every branch and every laptop.
COMPONENT_PORT=22695

# ── Sibling BFF origin (informational — same-origin proxy via nginx) ────────
# The static bundle's api.js uses a relative `basePath: /capabilities/chn/001/dsh`,
# so requests stay on the frontend origin and nginx reverse-proxies them to the
# BFF container by service name `chn-001-dsh-bff` on the shared platform network.
# The host-side BFF port (22328) is exposed by the BFF's own compose and is
# RECORDED HERE for tooling / diagnostics ONLY — neither the static bundle nor
# nginx.conf reads BFF_ORIGIN at runtime; the reverse proxy uses the service
# name. Re-derived deterministically with kind=bff:
#   BFF_PORT = 20000 + (int(sha256("BNK.RLVR.CAP.CHN.001.DSH:bff").hexdigest()[:8], 16) % 9000) = 22328
# Sibling TASK-007 owns that allocation.
BFF_ORIGIN=http://localhost:22328

# ── Branch slug (telemetry environment tag) ────────────────────────────────
# Frontend bus isolation has no broker side here — the value is carried only
# as a diagnostic / consistency tag (the static branch-badge is baked at build
# time into the source; it is intentionally NOT regenerated by the deployment
# layer per the TASK-008 scope guardrails).
BRANCH=task-008-scaffold-frontend-deployment-contract

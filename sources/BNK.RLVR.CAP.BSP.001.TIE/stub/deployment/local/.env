# BNK.RLVR.CAP.BSP.001.TIE — Tier Management stub — local environment.
#
# COMPONENT_PORT is deterministic from the capability id + kind per the
# Deployment contract (CLAUDE.md):
#   PORT = 20000 + (sha256("BNK.RLVR.CAP.BSP.001.TIE:api")[:8] mod 9000)
#        = 20393
# Recorded in /deployment/PORTS.md (no collision; salt :0 / no salt).
COMPONENT_PORT=20393

# Bus URLs — platform service-name form. The stub joins the shared external
# Docker network `reliever-platform`, on which RabbitMQ is reachable as
# `rabbitmq:5672` (real platform OR `platform.compose.yml` stand-in).
STUB_Stub__RabbitMq__HostName=rabbitmq
STUB_Stub__RabbitMq__Port=5672
STUB_Stub__RabbitMq__UserName=guest
STUB_Stub__RabbitMq__Password=guest
STUB_Stub__RabbitMq__VirtualHost=/

# Stub control — INACTIVE by default. Set to true to publish events.
# MUST remain false in production.
STUB_Stub__Active=false
STUB_Stub__EventsPerMinute=6

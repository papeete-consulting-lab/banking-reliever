# Deployment contract — local environment variables (CLAUDE.md §
# "Deployment contract"). Committed-by-design: no secrets here, only the
# deterministic component port + platform service-name URLs. Whitelisted
# in the repo .gitignore via `!sources/**/deployment/local/.env`.

# ── Deterministic component port ────────────────────────────────────────────
# COMPONENT_PORT = 20000 + (int(sha256(f"{capability_id}:{kind}").hexdigest()[:8], 16) % 9000)
# capability_id = BNK.RLVR.CAP.SUP.002.BEN , kind = api  → 26835
# Same capability + same kind → same port across every branch and every
# laptop. See /deployment/PORTS.md for the audit ledger.
COMPONENT_PORT=26835

# ── Application HTTP server (uvicorn) ───────────────────────────────────────
# Container-internal bindings only — host binding is in docker-compose.yml.
RELIEVER_HTTP_HOST=0.0.0.0
RELIEVER_HTTP_PORT=8000

# ── Persistence (Postgres — platform-owned, resolved by service name) ───────
# Service name `postgres` resolves on the shared `reliever-platform` network.
# Credentials match the platform's documented defaults and the in-folder
# `platform.compose.yml` stand-in so a fresh laptop works without further
# config. The `beneficiary_anchor` DB is created at platform-init time
# (real platform) or by the POSTGRES_DB env in the stand-in.
RELIEVER_PG_DSN=postgresql://reliever:reliever@postgres:5432/beneficiary_anchor

# ── Bus (RabbitMQ — platform-owned, resolved by service name) ───────────────
# AMQP credentials match the platform install defaults and the
# `platform.compose.yml` stand-in. Production overrides via External Secrets
# in the k8s overlay (per BNK.TECH.CAP.IDENTITY.001.SECRETS).
RELIEVER_AMQP_URL=amqp://admin:password@rabbitmq:5672/

# ── Branch isolation slug ───────────────────────────────────────────────────
# Carried into queue NAMES + the OTel environment tag — concurrent worktrees
# never cross-talk on the shared broker. Exchange NAMES stay shared
# (producer-owned). Host port is collapsed to the single deterministic
# COMPONENT_PORT above per the Deployment contract.
BRANCH=task-007-migrate-backend-to-deployment-contract

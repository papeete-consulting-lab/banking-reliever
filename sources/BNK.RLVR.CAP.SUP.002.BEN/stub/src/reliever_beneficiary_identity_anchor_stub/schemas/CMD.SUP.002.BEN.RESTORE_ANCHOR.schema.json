{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.banking/process/BNK.RLVR.CAP.SUP.002.BEN/schemas/CMD.SUP.002.BEN.RESTORE_ANCHOR.schema.json",
  "title": "RestoreAnchorCommand",
  "description": "Payload for CMD.SUP.002.BEN.RESTORE_ANCHOR — flip anchor_status from ARCHIVED back to ACTIVE. Rare, audited operation.",
  "type": "object",
  "additionalProperties": false,
  "required": ["command_id", "reason"],
  "properties": {
    "command_id": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$",
      "description": "UUIDv7 (RFC 9562 §5.7)."
    },
    "reason": {
      "type": "string",
      "enum": [
        "ARCHIVED_IN_ERROR",
        "REINSTATED_AFTER_REVIEW"
      ]
    },
    "comment": {
      "type": "string",
      "maxLength": 1000,
      "description": "Mandatory in spirit (RESTORE is rare); enforced by review at the API layer, not at the schema layer."
    }
  }
}

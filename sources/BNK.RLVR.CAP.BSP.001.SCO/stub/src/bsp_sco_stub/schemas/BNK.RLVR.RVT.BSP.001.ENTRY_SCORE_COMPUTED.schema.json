{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://reliever.banking/process/BNK.RLVR.CAP.BSP.001.SCO/schemas/BNK.RLVR.RVT.BSP.001.ENTRY_SCORE_COMPUTED.schema.json",
  "title": "EntryScoreComputedEvent",
  "description": "Payload of BNK.RLVR.RVT.BSP.001.ENTRY_SCORE_COMPUTED — emitted by AGG.SCORE_OF_BENEFICIARY when CMD.COMPUTE_ENTRY_SCORE is accepted. One-shot baseline. Carries BNK.RLVR.RES.BSP.001.ENTRY_SCORE.",
  "type": "object",
  "additionalProperties": false,
  "required": ["envelope", "case_id", "evaluation_id", "score_value", "model_version", "evaluation_type", "computation_timestamp", "contributing_factors"],
  "properties": {
    "envelope":      { "$ref": "#/$defs/Envelope" },
    "case_id":       { "$ref": "#/$defs/Uuidv7" },
    "evaluation_id": { "$ref": "#/$defs/Uuidv7", "description": "UUIDv7 of this evaluation row in the score history." },
    "score_value":   { "type": "number", "description": "Numeric value of the baseline behavioural score." },
    "model_version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
    "evaluation_type": {
      "type": "string",
      "const": "INITIAL",
      "description": "Per BNK.RLVR.OBJ.BSP.001.EVALUATION — INITIAL for the entry score (always for this RVT)."
    },
    "computation_timestamp": { "type": "string", "format": "date-time" },
    "contributing_factors": {
      "type": "array",
      "description": "Per-feature contribution to the baseline. Shape constrained but enum of feature names is model-versioned.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "weight", "value"],
        "properties": {
          "name":   { "type": "string" },
          "weight": { "type": "number" },
          "value":  { "type": ["number", "string", "null"] }
        }
      }
    }
  },
  "$defs": {
    "Uuidv7": {
      "type": "string",
      "format": "uuid",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-7[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$"
    },
    "Envelope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["message_id", "schema_version", "emitted_at", "emitting_capability", "correlation_id"],
      "properties": {
        "message_id":          { "$ref": "#/$defs/Uuidv7" },
        "schema_version":      { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "emitted_at":          { "type": "string", "format": "date-time" },
        "emitting_capability": { "type": "string", "const": "BNK.RLVR.CAP.BSP.001.SCO" },
        "correlation_id":      { "$ref": "#/$defs/Uuidv7", "description": "case_id for score-flow events." },
        "causation_id":        { "$ref": "#/$defs/Uuidv7", "description": "Set to the request_id of the originating COMPUTE_ENTRY_SCORE call (typically issued by POL.ON_ENROLMENT_COMPLETED)." }
      }
    }
  }
}

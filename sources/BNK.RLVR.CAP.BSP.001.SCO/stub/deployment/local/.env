# BNK.RLVR.CAP.BSP.001.SCO contract+stub — local deployment environment variables.
#
# Per CLAUDE.md § "Deployment contract": COMPONENT_PORT is deterministic from
# capability_id + kind:
#   PORT = 20000 + ( int(sha256("BNK.RLVR.CAP.BSP.001.SCO:api").hexdigest()[:8], 16) % 9000 )
#        = 23074
# Same capability + same kind → same port across every branch and laptop.
# See /deployment/PORTS.md for the audit ledger (no salt — collision-free).
#
# Bus targets reach the platform by SERVICE NAME on the shared external
# Docker network "reliever-platform" — never via localhost/host-port mapping.
# If the real platform is not installed, stand it up with platform.compose.yml
# (its RabbitMQ defaults to guest/guest, matching the stub's legacy creds).

# --- Component identity ---------------------------------------------------
COMPONENT_PORT=23074

# --- Bus (operational rail, RabbitMQ — platform) --------------------------
# Service name `rabbitmq` resolves on the reliever-platform external network.
# Credentials match the stub's legacy defaults (guest/guest) and the
# platform.compose.yml stand-in; production overrides via the real platform.
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# --- Stub behaviour (preserved verbatim from the legacy bundle) -----------
STUB_ACTIVE=true
STUB_CADENCE_PER_MIN=6
STUB_THRESHOLD_PROBABILITY=0.1
STUB_ENTRY_RATIO=0.1
STUB_CASE_POOL_SIZE=8
STUB_MODEL_VERSION=0.2.0
STUB_SCHEMA_VERSION=0.2.0
STUB_EXCHANGE_NAME=bsp.001.sco-events
STUB_LOG_LEVEL=INFO
